# ITcopilot Testing Environment

APP_NAME=ITcopilot
APP_VERSION=0.1.0
API_VERSION=v1
ENVIRONMENT=testing
DEBUG=true
LOG_LEVEL=INFO

HOST=127.0.0.1
PORT=8000

DATABASE_URL=sqlite+aiosqlite:///:memory:
AUTO_CREATE_SCHEMA=true

LOG_DIR=logs
LOG_JSON=false

SECRET_KEY=test-secret-key-not-for-production-use-only-32chars
JWT_SECRET=test-secret-key-not-for-production-use-only-32chars
JWT_ALGORITHM=HS256
AUTH_ENABLED=false
AUTH_ADMIN_PASSWORD=secret

ENABLE_AI=false
ENABLE_EXCEL=true
ENABLE_PARSER=true
ENABLE_REPORTS=true
ENABLE_CACHE=false
ENABLE_REST_API=true
ENABLE_BROKER_IMPORT=true
ENABLE_DASHBOARD=true
ENABLE_POWER_BI=false
ENABLE_EXPERIMENTAL=false

TAX_ASSESSMENT_YEAR=2025-26
TAX_REGIME=old
