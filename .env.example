# ITcopilot Environment Configuration
# Copy this file to .env and adjust values for your environment.

# Application
APP_NAME=ITcopilot
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
API_WORKERS=1

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://127.0.0.1:5173"]
CORS_ALLOW_CREDENTIALS=true

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/itcopilot.db
DATABASE_ECHO=false
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
# Auto-create tables on startup (dev/test only; use Alembic in production)
AUTO_CREATE_SCHEMA=true

# Logging
LOG_DIR=logs
LOG_ROTATION=10 MB
LOG_RETENTION=30 days
LOG_COMPRESSION=zip

# Security / Auth
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=30
AUTH_ENABLED=false
AUTH_DEFAULT_USERNAME=admin
# Dev/test only — plain password for /auth/token (never use in production)
AUTH_ADMIN_PASSWORD=secret
# Production only — bcrypt hash (required when ENVIRONMENT=production)
# Generate: python -c "from app.core.security import hash_password; print(hash_password('your-password'))"
# AUTH_ADMIN_PASSWORD_HASH=

# Tax Engine
TAX_ASSESSMENT_YEAR=2025-26
TAX_REGIME=old

# File Processing
MAX_UPLOAD_SIZE_MB=50
UPLOAD_DIR=uploads

# Frontend
VITE_API_BASE_URL=http://localhost:8000
