# Production environment template
# Copy to .env and set values before running: docker compose --profile production up

ENVIRONMENT=production
DEBUG=false
DATABASE_URL=postgresql+asyncpg://itcopilot:itcopilot@db:5432/itcopilot
AUTO_CREATE_SCHEMA=false
AUTH_ENABLED=true

# Required — generate with: python scripts/generate_production_secrets.py
SECRET_KEY=
AUTH_ADMIN_PASSWORD_HASH=
