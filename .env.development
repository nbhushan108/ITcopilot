# ITcopilot Development Environment

APP_NAME=ITcopilot
APP_VERSION=0.1.0
API_VERSION=v1
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG

HOST=0.0.0.0
PORT=8000
API_PREFIX=/api/v1

DATABASE_URL=sqlite+aiosqlite:///./data/itcopilot.db
AUTO_CREATE_SCHEMA=true

LOG_DIR=logs
LOG_ROTATION=10 MB
LOG_RETENTION=30 days
LOG_COMPRESSION=zip
LOG_JSON=false

SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_SECRET=
JWT_ALGORITHM=HS256
AUTH_ENABLED=false
AUTH_ADMIN_PASSWORD=secret

ENABLE_AI=false
ENABLE_EXCEL=true
ENABLE_PARSER=true
ENABLE_REPORTS=true
ENABLE_CACHE=false
ENABLE_REST_API=true
ENABLE_BROKER_IMPORT=true
ENABLE_DASHBOARD=true
ENABLE_POWER_BI=false
ENABLE_EXPERIMENTAL=false

TAX_ASSESSMENT_YEAR=2025-26
TAX_REGIME=old
