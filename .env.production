# ITcopilot Production Environment
# Copy values into your secret manager or deployment platform.

APP_NAME=ITcopilot
APP_VERSION=0.1.0
API_VERSION=v1
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

HOST=0.0.0.0
PORT=8000

DATABASE_URL=postgresql+asyncpg://itcopilot:itcopilot@db:5432/itcopilot
AUTO_CREATE_SCHEMA=false

LOG_DIR=/var/log/itcopilot
LOG_ROTATION=50 MB
LOG_RETENTION=90 days
LOG_COMPRESSION=zip
LOG_JSON=true

SECRET_KEY=
JWT_SECRET=
JWT_ALGORITHM=HS256
AUTH_ENABLED=true
AUTH_ADMIN_PASSWORD_HASH=

ENABLE_AI=false
ENABLE_EXCEL=true
ENABLE_PARSER=true
ENABLE_REPORTS=true
ENABLE_CACHE=false
ENABLE_REST_API=true
ENABLE_BROKER_IMPORT=true
ENABLE_DASHBOARD=true
ENABLE_POWER_BI=false
ENABLE_EXPERIMENTAL=false
CACHE_URL=

TAX_ASSESSMENT_YEAR=2025-26
TAX_REGIME=old
